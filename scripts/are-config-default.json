{
  "_version": "1.0",
  "_description": "Astrophage Extender configuration. Adjust thresholds to tune the crew.",
  "output_shaper": {
    "enabled": true,
    "grep_max_matches": 30,
    "cat_max_lines": 300,
    "git_log_max": 40,
    "git_diff_max_lines": 400,
    "find_max_results": 50,
    "never_modify": [
      "jest", "vitest", "pytest", "mocha", "cargo test", "go test",
      "npm test", "npx test", "npm run", "cargo build", "make",
      "cmake", "webpack", "rollup", "tsc", "npm install", "pip install",
      "cargo add", "apt", "brew", "docker", "kubectl"
    ]
  },
  "read_gate": {
    "enabled": true,
    "large_file_threshold_lines": 200,
    "large_file_threshold_bytes": 8000,
    "warn_on_reread": true,
    "max_reread_before_warn": 1
  },
  "compact_advisor": {
    "enabled": true,
    "tool_call_threshold": 40,
    "phase_detection": true,
    "ecc_deference": true
  }
}
